 16.         gen double twostep       = .
 17.         gen double chi2_J        = .
 18.         gen double chi2_J_u      = .
 19.         gen double overid_df     = .
 20.         gen double chi2_J_p      = .
 21.         gen double chi2_J_u_p    = .
 22. 
.         capture replace N = e(N)
 23.         capture replace N_g = e(N_g)
 24.         capture replace N_clust = e(N_clust)
 25.         capture replace g_min = e(g_min)
 26.         capture replace g_avg = e(g_avg)
 27.         capture replace g_max = e(g_max)
 28.         capture replace rank = e(rank)
 29.         capture replace zrank = e(zrank)
 30.         capture replace zrank_nl = e(zrank_nl)
