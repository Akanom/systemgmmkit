. program define dump_xtdpdgmm_ereturn
  1.     syntax, Spec(string) Outfile(string)
  2. 
.     tempfile tmp
  3.     tempname handle
  4. 
.     postfile `handle' str80 spec str20 kind str80 name double value_num str244 value_text using `
> tmp', replace
  5. 
.     local scalars : e(scalars)
  6.     foreach s of local scalars {
  7.         capture scalar __v = e(`s')
  8.         if !_rc {
  9.             post `handle' ("`spec'") ("scalar") ("`s'") (__v) ("")
 10.         }
 11.     }
 12. 
.     local macros : e(macros)
 13.     foreach m of local macros {
 14.         local __txt `"`e(`m')'"'
 15.         post `handle' ("`spec'") ("macro") ("`m'") (.) (`"`__txt'"')
 16.     }
 17. 
.     postclose `handle'
 18. 
.     preserve
 19.         use `tmp', clear
 20.         export delimited using "`outfile'", replace
 21.     restore
