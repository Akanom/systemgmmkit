  1.     syntax, Spec(string) Outfile(string)
  2. 
.     preserve
  3.         clear
  4.         set obs 1
  5. 
.         gen str80 spec = "`spec'"
  6. 
.         gen double N             = .
  7.         gen double N_g           = .
  8.         gen double N_clust       = .
  9.         gen double g_min         = .
 10.         gen double g_avg         = .
 11.         gen double g_max         = .
 12.         gen double rank          = .
 13.         gen double zrank         = .
 14.         gen double zrank_nl      = .
