. capture program drop export_last_xtdpdgmm

. program define export_last_xtdpdgmm
  1.     syntax, SPEC(string) OUTPUT(string)
  2. 
.     tempname b V
  3.     matrix `b' = e(b)
  4.     matrix `V' = e(V)
  5. 
.     local cn : colfullnames `b'
  6.     local k = colsof(`b')
  7. 
.     preserve
  8.         clear
  9.         set obs `k'
 10. 
.         gen str80 spec = "`spec'"
 11.         gen str80 term = ""
 12.         gen double stata_coef = .
 13.         gen double stata_std_err = .
 14.         gen double stata_z = .
 15.         gen double stata_p_value = .
 16. 
.         local j = 1
 17.         foreach nm of local cn {
 18.             replace term = "`nm'" in `j'
 19.             replace stata_coef = el(`b', 1, `j') in `j'
 20.             replace stata_std_err = sqrt(el(`V', `j', `j')) in `j'
 21.             replace stata_z = stata_coef / stata_std_err in `j'
 22.             replace stata_p_value = 2 * normal(-abs(stata_z)) in `j'
 23.             local ++j
 24.         }
 25. 
.         gen double e_N = .
 26.         gen double e_N_g = .
 27.         gen double e_j = .
 28.         gen double e_j_p = .
 29.         gen double e_hansen = .
 30.         gen double e_hansenp = .
 31.         gen double e_sargan = .
 32.         gen double e_sarganp = .
 33.         gen double e_ar1 = .
 34.         gen double e_ar1p = .
 35.         gen double e_ar2 = .
 36.         gen double e_ar2p = .
 37. 
.         capture replace e_N = e(N) in 1
 38.         capture replace e_N_g = e(N_g) in 1
 39.         capture replace e_j = e(j) in 1
 40.         capture replace e_j_p = e(j_p) in 1
 41.         capture replace e_hansen = e(hansen) in 1
 42.         capture replace e_hansenp = e(hansenp) in 1
 43.         capture replace e_sargan = e(sargan) in 1
 44.         capture replace e_sarganp = e(sarganp) in 1
 45.         capture replace e_ar1 = e(ar1) in 1
 46.         capture replace e_ar1p = e(ar1p) in 1
 47.         capture replace e_ar2 = e(ar2) in 1
 48.         capture replace e_ar2p = e(ar2p) in 1
 49. 
.         export delimited using "`output'", replace
 50.     restore
 51. end

