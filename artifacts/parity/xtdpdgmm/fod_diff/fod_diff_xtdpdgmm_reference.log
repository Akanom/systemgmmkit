 33.         capture replace chi2_J = e(chi2_J)
 34.         capture replace chi2_J_u = e(chi2_J_u)
 35. 
.         capture replace overid_df = e(zrank) - e(rank)
 36.         capture replace chi2_J_p = chi2tail(overid_df, chi2_J) if overid_df < . & chi2_J < .
