. program define dump_failed_postestimation
  1.     syntax, Spec(string) Command(string) Outfile(string) RC(integer)
  2. 
.     preserve
  3.         clear
  4.         set obs 1
  5. 
.         gen str80 spec = "`spec'"
  6.         gen str40 command = "`command'"
  7.         gen str20 kind = "failed"
  8.         gen str80 name = "_rc"
  9.         gen double value_num = `rc'
 10.         gen str244 value_text = ""
 11. 
.         export delimited using "`outfile'", replace
 12.     restore
 13. end

