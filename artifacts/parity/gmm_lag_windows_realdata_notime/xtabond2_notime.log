. program define export_model
  1.     syntax, MODEL(name)
  2. 
.     estimates store `model'
  3. 
.     scalar __overid_df = .
  4.     scalar __overid_source = 0
  5. 
.     capture scalar __overid_df = e(j_df)
  6.     if !missing(__overid_df) {
  7.         scalar __overid_source = 1
  8.     }
  9. 
.     if missing(__overid_df) {
 10.         capture scalar __overid_df = e(hansen_df)
 11.         if !_rc & !missing(__overid_df) {
 12.             scalar __overid_source = 2
 13.         }
 14.     }
 15. 
.     if missing(__overid_df) {
 16.         capture scalar __overid_df = e(df_hansen)
 17.         if !_rc & !missing(__overid_df) {
 18.             scalar __overid_source = 3
 19.         }
 20.     }
 21. 
.     if missing(__overid_df) {
 22.         capture scalar __overid_df = e(j) - colsof(e(b))
 23.         if !_rc & !missing(__overid_df) {
 24.             scalar __overid_source = 4
 25.         }
 26.     }
 27. 
.     if missing(__overid_df) | __overid_df < 0 {
 28.         display as error "BLOCKED: overidentification df could not be recovered."
 29.         ereturn list
 30.         exit 459
 31.     }
 32. 
.     display "MODEL=`model'"
 33.     display "N=" e(N)
 34.     display "N_g=" e(N_g)
 35.     display "j=" e(j)
 36.     display "j_df_effective=" __overid_df
 37.     display "j_df_source=" __overid_source
 38.     display "hansenp=" e(hansenp)
 39.     display "sarganp=" e(sarganp)
 40.     display "ar1p=" e(ar1p)
 41.     display "ar2p=" e(ar2p)
 42. 
.     matrix b = e(b)
 43.     matrix V = e(V)
 44.     local names : colnames b
 45.     local k = colsof(b)
 46. 
.     preserve
 47.         clear
 48.         set obs `k'
 49.         gen str32 model = "`model'"
 50.         gen str32 param = ""
 51.         gen coef = .
 52.         gen std_err = .
 53. 
.         local i = 1
 54.         foreach nm of local names {
 55.             replace param = "`nm'" in `i'
 56.             replace coef = b[1, `i'] in `i'
 57.             replace std_err = sqrt(V[`i', `i']) in `i'
 58.             local ++i
 59.         }
 60. 
.         export delimited using "artifacts/parity/gmm_lag_windows_realdata_notime/`model'_params.c
> sv", replace
 61.     restore
 62. 
.     preserve
 63.         clear
 64.         set obs 1
 65.         gen str32 model = "`model'"
 66.         gen N = e(N)
 67.         gen N_g = e(N_g)
 68.         gen k_instruments = e(j)
 69.         gen k_params = colsof(e(b))
 70.         gen overid_df = __overid_df
 71.         gen overid_df_source = __overid_source
 72.         gen hansen_p = e(hansenp)
 73.         gen sargan_p = e(sarganp)
 74.         gen ar1_p = e(ar1p)
 75.         gen ar2_p = e(ar2p)
 76. 
.         export delimited using "artifacts/parity/gmm_lag_windows_realdata_notime/`model'_diagnost
> ics.csv", replace
 77.     restore
 78. end

