. program define sgmmkit_export_xtabond2
  1.     syntax, MODEL(name)
  2. 
.     estimates store `model'
  3. 
.     display "MODEL=`model'"
  4.     display "N=" e(N)
  5.     display "N_g=" e(N_g)
  6.     display "j=" e(j)
  7.     display "j_df_raw=" e(j_df)
  8. 
.     scalar __sgmmkit_overid_df = .
  9.     scalar __sgmmkit_overid_df_source = 0
 10. 
.     capture scalar __sgmmkit_overid_df = e(j_df)
 11.     if !missing(__sgmmkit_overid_df) {
 12.         scalar __sgmmkit_overid_df_source = 1
 13.     }
 14. 
.     if missing(__sgmmkit_overid_df) {
 15.         capture scalar __sgmmkit_overid_df = e(hansen_df)
 16.         if !_rc & !missing(__sgmmkit_overid_df) {
 17.             scalar __sgmmkit_overid_df_source = 2
 18.         }
 19.     }
 20. 
.     if missing(__sgmmkit_overid_df) {
 21.         capture scalar __sgmmkit_overid_df = e(df_hansen)
 22.         if !_rc & !missing(__sgmmkit_overid_df) {
 23.             scalar __sgmmkit_overid_df_source = 3
 24.         }
 25.     }
 26. 
.     if missing(__sgmmkit_overid_df) {
 27.         capture scalar __sgmmkit_overid_df = e(j) - colsof(e(b))
 28.         if !_rc & !missing(__sgmmkit_overid_df) {
 29.             scalar __sgmmkit_overid_df_source = 4
 30.         }
 31.     }
 32. 
.     if missing(__sgmmkit_overid_df) | __sgmmkit_overid_df < 0 {
 33.         display as error "BLOCKED: could not recover Hansen/Sargan overidentification degrees 
> of freedom."
 34.         ereturn list
 35.         exit 459
 36.     }
 37. 
.     scalar __sgmmkit_hansen_p = .
 38.     scalar __sgmmkit_sargan_p = .
 39.     scalar __sgmmkit_ar1_p = .
 40.     scalar __sgmmkit_ar2_p = .
 41. 
.     capture scalar __sgmmkit_hansen_p = e(hansenp)
 42.     capture scalar __sgmmkit_sargan_p = e(sarganp)
 43.     capture scalar __sgmmkit_ar1_p = e(ar1p)
 44.     capture scalar __sgmmkit_ar2_p = e(ar2p)
 45. 
.     display "j_df_effective=" __sgmmkit_overid_df
 46.     display "j_df_source=" __sgmmkit_overid_df_source
 47.     display "k_instruments_ej=" e(j)
 48.     display "k_params_colsof_eb=" colsof(e(b))
 49.     display "hansenp=" __sgmmkit_hansen_p
 50.     display "sarganp=" __sgmmkit_sargan_p
 51.     display "ar1p=" __sgmmkit_ar1_p
 52.     display "ar2p=" __sgmmkit_ar2_p
 53. 
.     matrix __b = e(b)
 54.     matrix __V = e(V)
 55.     local names : colnames __b
 56.     local k = colsof(__b)
 57. 
.     preserve
 58.         clear
 59.         set obs `k'
 60.         gen str64 model = "`model'"
 61.         gen str64 param = ""
 62.         gen coef = .
 63.         gen std_err = .
 64.         gen z = .
 65.         gen p_value = .
 66. 
.         local i = 1
 67.         foreach nm of local names {
 68.             replace param = "`nm'" in `i'
 69.             replace coef = __b[1, `i'] in `i'
 70.             replace std_err = sqrt(__V[`i', `i']) in `i'
 71.             replace z = coef / std_err in `i'
 72.             replace p_value = 2 * normal(-abs(z)) in `i'
 73.             local ++i
 74.         }
 75. 
.         export delimited using "artifacts/parity/gmm_lag_windows_realdata/`model'_params.csv", re
> place
 76.     restore
 77. 
.     preserve
 78.         clear
 79.         set obs 1
 80.         gen str64 model = "`model'"
 81.         gen N = e(N)
 82.         gen N_g = e(N_g)
 83.         gen k_instruments = e(j)
 84.         gen k_params = colsof(e(b))
 85.         gen overid_df = __sgmmkit_overid_df
 86.         gen overid_df_source = __sgmmkit_overid_df_source
 87.         gen hansen_p = __sgmmkit_hansen_p
 88.         gen sargan_p = __sgmmkit_sargan_p
 89.         gen ar1_p = __sgmmkit_ar1_p
 90.         gen ar2_p = __sgmmkit_ar2_p
 91. 
.         export delimited using "artifacts/parity/gmm_lag_windows_realdata/`model'_diagnostics.csv
> ", replace
 92.     restore
 93. end

